# Database
POSTGRES_USER=myapp
POSTGRES_PASSWORD=changeme
POSTGRES_DB=myapp
DATABASE_URL=postgresql://myapp:changeme@localhost:5432/myapp

# Payload CMS
PAYLOAD_SECRET=your-secret-key-change-in-production

# Server URL (used for live preview & media URLs)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Site name (used in email subjects & footers)
NEXT_PUBLIC_SITE_NAME=My App

# ─── Email / Resend ───────────────────────────────────────────────────────────
# Required for sending emails in production. Get your key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "from" address for all outgoing emails (must be verified in Resend)
EMAIL_FROM=noreply@yourdomain.com

# Admin notification recipient for contact form submissions
ADMIN_EMAIL=admin@yourdomain.com

# Optional: Resend Audience ID for newsletter subscriptions
# Create an Audience in your Resend dashboard and paste the ID here
RESEND_AUDIENCE_ID=aud_xxxxxxxxxxxxxxxxxxxx

# ─── S3 Storage ───────────────────────────────────────────────────────────────
# Required for file uploads. Supports any S3-compatible provider.
# Files are served via presigned URLs (no public bucket policy needed).
#
# Cloudflare R2 (recommended — 10GB free, zero egress fees):
S3_REGION=auto
S3_BUCKET=my-app-uploads
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# AWS S3:
# S3_REGION=us-east-1
# S3_BUCKET=my-app-uploads
# S3_ACCESS_KEY=your_aws_key
# S3_SECRET_KEY=your_aws_secret
# S3_ENDPOINT=   # leave empty for AWS

# DigitalOcean Spaces:
# S3_REGION=fra1
# S3_BUCKET=my-app-uploads
# S3_ACCESS_KEY=your_do_key
# S3_SECRET_KEY=your_do_secret
# S3_ENDPOINT=https://fra1.digitaloceanspaces.com

# Optional: presigned URL expiry in seconds (default: 604800 = 7 days)
# S3_PRESIGN_EXPIRY=604800
